# ============================================================
# 1. Python 编译/优化后的字节码文件
# ============================================================
__pycache__/           # Python 3 的字节码缓存目录
*.py[codz]             # 匹配 .pyc, .pyo, .pyd 等编译文件
*$py.class             # 某些 Python 实现生成的类文件

# ============================================================
# 2. C 扩展库（编译后动态链接库）
# ============================================================
*.so                   # Linux/Unix 共享库

# ============================================================
# 3. 打包与分发相关
# ============================================================
.Python                # 可能由 virtualenv 等生成的 Python 副本
build/                 # 构建目录（setuptools 等）
develop-eggs/          # 开发阶段的 egg 目录
dist/                  # 分发打包输出目录（如 .whl, .tar.gz）
downloads/             # 下载的依赖包存放目录
eggs/                  # 解压后的 egg 包目录
.eggs/                 # 同上，隐藏版本
lib/                   # 安装的库文件
lib64/                 # 64 位库文件
parts/                 # 组件构建目录（如 zc.buildout）
sdist/                 # 源码分发包输出目录
var/                   # 运行时变量文件
wheels/                # wheel 包存放目录
share/python-wheels/   # 共享 wheel 包目录
*.egg-info/            # egg 元信息目录
.installed.cfg         # setuptools 安装配置
*.egg                  # egg 包文件
MANIFEST               # 清单文件（通常由 setuptools 生成）

# ============================================================
# 4. PyInstaller 相关（打包为可执行文件时产生）
# ============================================================
*.manifest             # 清单文件
*.spec                 # PyInstaller 规格文件

# ============================================================
# 5. 安装日志与临时文件
# ============================================================
pip-log.txt            # pip 日志
pip-delete-this-directory.txt  # pip 临时标记文件

# ============================================================
# 6. 单元测试与覆盖率报告
# ============================================================
htmlcov/               # coverage 生成的 HTML 报告目录
.tox/                  # tox 测试环境目录
.nox/                  # nox 测试环境目录
.coverage              # coverage 数据文件
.coverage.*            # 其他 coverage 数据文件
.cache                 # pytest 或其他工具的缓存
nosetests.xml          # nose 测试报告
coverage.xml           # coverage XML 报告
*.cover                # coverage 数据文件
*.py.cover             # coverage 数据文件（带源码）
.hypothesis/           # Hypothesis 状态缓存
.pytest_cache/         # pytest 缓存目录
cover/                 # 旧版 coverage 目录

# ============================================================
# 7. 国际化与翻译文件
# ============================================================
*.mo                   # 编译后的消息文件
*.pot                  # 可移植对象模板（翻译源）

# ============================================================
# 8. Django 框架特定
# ============================================================
*.log                  # 日志文件
local_settings.py      # 本地设置（通常包含敏感信息）
db.sqlite3             # SQLite 数据库文件
db.sqlite3-journal     # SQLite 日志

# ============================================================
# 9. Flask 框架特定
# ============================================================
instance/              # Flask 实例文件夹
.webassets-cache       # webassets 缓存

# ============================================================
# 10. Scrapy 爬虫框架
# ============================================================
.scrapy                # Scrapy 项目缓存

# ============================================================
# 11. Sphinx 文档生成
# ============================================================
docs/_build/           # 文档构建输出目录

# ============================================================
# 12. PyBuilder 构建工具
# ============================================================
.pybuilder/            # PyBuilder 工作目录
target/                # PyBuilder 输出目录

# ============================================================
# 13. Jupyter Notebook
# ============================================================
.ipynb_checkpoints/    # Notebook 自动检查点文件夹

# ============================================================
# 14. IPython 配置
# ============================================================
profile_default/       # IPython 默认配置文件目录
ipython_config.py      # IPython 配置文件

# ============================================================
# 15. pyenv（Python 版本管理）—— 默认不忽略 .python-version，可根据需要取消注释
# ============================================================
# .python-version      # pyenv 的 Python 版本文件（建议保留）

# ============================================================
# 16. pipenv（依赖管理）—— 默认不忽略 Pipfile.lock，根据项目决定
# ============================================================
# Pipfile.lock         # pipenv 锁定文件（建议提交）

# ============================================================
# 17. UV（现代 Python 包管理器）—— 默认不忽略 uv.lock
# ============================================================
# uv.lock              # UV 锁定文件（建议提交）

# ============================================================
# 18. Poetry（依赖管理）—— 默认不忽略 poetry.lock 和 poetry.toml
# ============================================================
# poetry.lock          # Poetry 锁定文件（建议提交）
# poetry.toml          # Poetry 配置文件（可提交）

# ============================================================
# 19. PDM（依赖管理）
# ============================================================
.pdm-python            # PDM 的 Python 版本标记（建议忽略）
.pdm-build/            # PDM 构建目录
# pdm.lock             # 锁定文件（建议提交）
# pdm.toml             # 项目配置（可提交）

# ============================================================
# 20. Pixi（类似 conda 的包管理器）
# ============================================================
.pixi                  # Pixi 创建的虚拟环境目录
# pixi.lock            # 锁定文件（建议提交）

# ============================================================
# 21. PEP 582（本地包目录，如 pyflow 或 pdm 使用）
# ============================================================
__pypackages__/        # 本地包目录

# ============================================================
# 22. Celery 分布式任务队列
# ============================================================
celerybeat-schedule    # Celery 调度文件
celerybeat.pid         # Celery 进程 ID 文件

# ============================================================
# 23. Redis 数据库
# ============================================================
*.rdb                  # Redis 快照文件
*.aof                  # Redis 追加日志文件
*.pid                  # Redis 进程 ID 文件

# ============================================================
# 24. RabbitMQ 消息队列
# ============================================================
mnesia/                # RabbitMQ 数据目录
rabbitmq/              # RabbitMQ 通用目录
rabbitmq-data/         # RabbitMQ 数据目录

# ============================================================
# 25. ActiveMQ 消息队列
# ============================================================
activemq-data/         # ActiveMQ 数据目录

# ============================================================
# 26. SageMath（数学软件）
# ============================================================
*.sage.py              # SageMath 解析生成的 Python 文件

# ============================================================
# 27. 虚拟环境（所有常用名称）
# ============================================================
.env                   # 环境变量文件
.envrc                 # direnv 环境配置
.venv/                 # Python 虚拟环境目录（常见）
env/                   # 虚拟环境目录
venv/                  # 虚拟环境目录
ENV/                   # 虚拟环境目录
env.bak/               # 备份的虚拟环境
venv.bak/              # 备份的虚拟环境

# ============================================================
# 28. IDE / 编辑器配置（部分）
# ============================================================
# Spyder
.spyderproject         # Spyder 项目设置
.spyproject            # Spyder 项目设置（旧版）

# Rope（Python 重构库）
.ropeproject           # Rope 项目缓存

# PyCharm（具体模板在单独的 JetBrains.gitignore，这里可取消注释 .idea/）
# .idea/               # 整个 PyCharm 项目目录（取消注释后全局忽略）

# Visual Studio Code（同样有单独模板，这里可取消注释 .vscode/）
# .vscode/             # 整个 VS Code 配置目录

# 其他临时文件
tempCodeRunnerFile.py  # 部分编辑器用于临时运行代码的文件

# ============================================================
# 29. 静态类型检查工具
# ============================================================
# mypy
.mypy_cache/           # mypy 类型检查缓存
.dmypy.json            # mypy 守护进程状态
dmypy.json             # 同上

# Pyre（Facebook 类型检查器）
.pyre/                 # Pyre 缓存目录

# pytype（Google 类型检查器）
.pytype/               # pytype 缓存目录

# Ruff（快速 Python linter）
.ruff_cache/           # Ruff 缓存目录

# ============================================================
# 30. Cython 调试符号
# ============================================================
cython_debug/          # Cython 调试符号目录

# ============================================================
# 31. Abstra（流程自动化框架）
# ============================================================
.abstra/               # Abstra 的凭证、本地状态和设置

# ============================================================
# 32. 文档生成（其他）
# ============================================================
/site                  # mkdocs 等生成的网站目录

# ============================================================
# 33. PyPI 配置文件
# ============================================================
.pypirc                # PyPI 认证配置（包含敏感信息）

# ============================================================
# 34. Marimo（交互式笔记本）
# ============================================================
marimo/_static/        # Marimo 静态资源
marimo/_lsp/           # Marimo LSP 相关
__marimo__/            # Marimo 运行时目录

# ============================================================
# 35. Streamlit（Web 应用框架）
# ============================================================
.streamlit/secrets.toml  # Streamlit 的密钥配置文件（敏感）